#pragma once

// Copy this file to wifi_secrets.h and fill your actual credentials.
// IMPORTANT: wifi_secrets.h is git-ignored.
//
// Priority order:
//   Candidate 1 -> Candidate 2 -> Candidate 3 -> ...
// The firmware tries each candidate until one connects.

static const char* const STA_CANDIDATE_SSIDS[] = {
  "YourWiFi-1",
  "YourWiFi-2",
};

static const char* const STA_CANDIDATE_PASSWORDS[] = {
  "YourPassword-1",
  "YourPassword-2",
};

static_assert(
  sizeof(STA_CANDIDATE_SSIDS) / sizeof(STA_CANDIDATE_SSIDS[0]) ==
  sizeof(STA_CANDIDATE_PASSWORDS) / sizeof(STA_CANDIDATE_PASSWORDS[0]),
  "STA SSID/PASSWORD array sizes must match"
);

#define STA_CANDIDATE_COUNT \
  (sizeof(STA_CANDIDATE_SSIDS) / sizeof(STA_CANDIDATE_SSIDS[0]))
